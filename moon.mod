name = "gmlewis/step"

version = "0.1.14"

import {
  "gmlewis/base64@0.16.10",
  "gmlewis/flate@0.36.9",
  "gmlewis/fonts@0.19.11",
  "gmlewis/gzip@0.34.9",
  "gmlewis/io@0.23.12",
  "moonbitlang/async@0.19.2",
  "moonbitlang/x@0.4.45",
  "TheWaWaR/clap@0.2.6",
}

readme = "README.md"

repository = "https://github.com/gmlewis/moonbit-step"

license = "Apache-2.0"

keywords = [ "cad", "step", "3d", "modeling" ]

description = "Port of https://github.com/tscircuit/stepts to MoonBit"

preferred_target = "native"
